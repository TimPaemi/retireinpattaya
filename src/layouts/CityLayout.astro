---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { SITE } from '../site.config';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import KeyFacts from '../components/KeyFacts.astro';
import GuideHero from '../components/GuideHero.astro';
import Disclaimer from '../components/Disclaimer.astro';
import SourceList from '../components/SourceList.astro';
import RelatedGuides from '../components/RelatedGuides.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import GlossaryTooltips from '../components/GlossaryTooltips.astro';
import ArticleEnhance from '../components/ArticleEnhance.astro';

interface Heading { depth: number; slug: string; text: string; }
interface Props { entry: CollectionEntry<'cities'>; headings?: Heading[]; }
const { entry, headings = [] } = Astro.props;
const d = entry.data;
const words = entry.body.split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(words / 200));
const url = new URL(`/${entry.slug}/`, SITE.url).href;
const palette = entry.slug === 'phuket' ? 'cost-of-living' : 'money';

// related = the destination comparison guides
const all = await getCollection('guides', ({ data }) => (import.meta.env.PROD ? !data.draft : true));
const related = all.filter((g) => g.data.pillar === 'reality-checks' && g.data.contentType === 'comparison')
  .slice(0, 4).map((g) => ({ slug: g.slug, pillar: g.data.pillar, title: g.data.title, description: g.data.description }));

const schemas = [
  {
    '@context': 'https://schema.org', '@type': 'Article',
    headline: d.title, description: d.description,
    datePublished: d.publishDate.toISOString(), dateModified: d.lastReviewed.toISOString(),
    author: { '@type': 'Organization', name: SITE.name }, publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
    mainEntityOfPage: url, about: { '@type': 'Place', name: d.city, address: { '@type': 'PostalAddress', addressCountry: 'TH', addressLocality: d.city } },
  },
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: d.city, item: url },
    ],
  },
  ...(d.faq.length ? [{
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: d.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  }] : []),
];
---
<BaseLayout title={d.title} description={d.description} type="article" image={d.heroImage ?? `/og/city-${entry.slug}.png`} schemas={schemas}>
  <div class="section"><div class="container">
    <Breadcrumbs crumbs={[{ label: d.city }]} />
    <div class="article-grid">
      <article>
        <header class="article-head flow">
          <p class="eyebrow">🌏 Retire in Thailand · {readingMinutes} min read</p>
          <h1>{d.title}</h1>
          <p class="lead">{d.intro}</p>
          <p class="city-quiz-prompt">🧭 Not sure which Thai city fits you? <a href="/tools/where-in-thailand/">Take the 2-minute quiz →</a></p>
          <div class="meta-row reviewed"><span>By <strong>The Retire in Pattaya Editorial Team</strong></span><span>· Last reviewed {d.lastReviewed.toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'})}</span></div>
        </header>
        <div class="guide-hero-wrap"><GuideHero pillar={palette} slug={entry.slug} height={200} /></div>
        <KeyFacts facts={d.keyFacts} />
        <div class="prose flow"><slot /></div>
        <Disclaimer topic="general" />
        <SourceList sources={d.sources} />
        <RelatedGuides guides={related} />
        <NewsletterSignup />
      </article>
      <aside class="article-aside"><div class="aside-sticky">
        <nav class="toc" aria-label="On this page"><p class="toc-title">On this page</p>
          <ol>{headings.filter((h)=>h.depth===2).map((h)=>(<li><a href={`#${h.slug}`}>{h.text}</a></li>))}</ol>
        </nav>
      </div></aside>
    </div>
  </div></div>
  <GlossaryTooltips /><ArticleEnhance />
</BaseLayout>
<style>
  .article-grid { display: grid; grid-template-columns: minmax(0,1fr) 16rem; gap: var(--space-8); align-items: start; margin-top: var(--space-5); }
  article { min-width: 0; } .article-head { margin-bottom: var(--space-5); }
  .city-quiz-prompt { font-size: var(--text-sm); background: var(--brand-050); border:1px solid var(--brand-100); border-radius: var(--radius); padding: var(--space-2) var(--space-4); display:inline-block; } .guide-hero-wrap { margin-bottom: var(--space-5); }
  .aside-sticky { position: sticky; top: 96px; }
  .toc { font-size: var(--text-sm); } .toc-title { text-transform: uppercase; letter-spacing: .06em; font-size: var(--text-xs); font-weight: 700; color: var(--ink-500); margin-bottom: var(--space-2); }
  .toc ol { list-style: none; padding: 0; margin: 0; border-left: 2px solid var(--line); } .toc a { display: block; padding: var(--space-1) var(--space-3); color: var(--ink-700); text-decoration: none; border-left: 2px solid transparent; margin-left: -2px; } .toc a:hover { color: var(--brand-700); border-left-color: var(--brand-500); background: var(--brand-050); }
  @media (max-width: 980px) { .article-grid { grid-template-columns: 1fr; } .article-aside { display: none; } }
</style>
