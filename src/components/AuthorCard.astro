---
interface Props { name: string; role: string; shortBio: string; slug: string; credentials?: string[]; }
const { name, role, shortBio, slug, credentials = [] } = Astro.props;
const initials = name.split(' ').map((w) => w[0]).slice(0, 2).join('');
---
<aside class="author-card">
  <div class="author-avatar" aria-hidden="true">{initials}</div>
  <div>
    <p class="author-name"><a href={`/authors/${slug}/`}>{name}</a></p>
    <p class="author-role">{role}</p>
    <p class="author-bio">{shortBio}</p>
    {credentials.length > 0 && (
      <ul class="author-creds">{credentials.slice(0, 2).map((c) => <li>{c}</li>)}</ul>
    )}
  </div>
</aside>
<style>
  .author-card { display: flex; gap: var(--space-4); align-items: flex-start; background: var(--surface-soft); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: var(--space-5); margin-top: var(--space-8); }
  .author-avatar { flex: 0 0 auto; width: 56px; height: 56px; border-radius: 50%; background: var(--brand-700); color: #fff; display: grid; place-items: center; font-weight: 700; font-size: var(--text-lg); }
  .author-name { font-weight: 700; font-size: var(--text-lg); }
  .author-name a { text-decoration: none; color: var(--brand-900); }
  .author-role { color: var(--ink-500); font-size: var(--text-sm); }
  .author-bio { margin-top: var(--space-2); }
  .author-creds { margin-top: var(--space-2); padding-left: var(--space-5); font-size: var(--text-sm); color: var(--ink-500); }
</style>
