---
import { FORMS, AFFILIATES } from '../site.config';
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
const hasPartner = AFFILIATES.insurance && AFFILIATES.insurance !== '#';
---
<aside class={`ins-lead ${compact ? 'is-compact' : ''}`}>
  <div>
    <p class="ins-eyebrow">Get a real quote</p>
    <p class="ins-head">Compare expat health insurance for your age</p>
    <p class="ins-sub">Premiums vary enormously by age and health history. The only way to know your number is a real quote — it's free and takes a few minutes.</p>
  </div>
  <div class="ins-cta">
    {hasPartner
      ? <a class="btn btn-accent btn-lg" href={AFFILIATES.insurance} rel="sponsored noopener" target="_blank">Compare quotes →</a>
      : <a class="btn btn-accent btn-lg" href="/healthcare/">Read the insurance guide →</a>}
    <p class="ins-disc">We may earn a commission, at no cost to you. We only work with reputable insurers — never predatory sellers.</p>
  </div>
</aside>
<style>
  .ins-lead { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-5); align-items: center; background: var(--sand-100); border: 1px solid var(--line-strong); border-left: 5px solid var(--accent-500); border-radius: var(--radius-lg); padding: var(--space-5); margin-block: var(--space-6); }
  .ins-lead.is-compact { grid-template-columns: 1fr; }
  .ins-eyebrow { text-transform: uppercase; letter-spacing: .07em; font-size: var(--text-xs); font-weight: 700; color: var(--accent-700); }
  .ins-head { font-family: var(--font-serif); font-size: var(--text-lg); color: var(--brand-900); margin-top: var(--space-1); }
  .ins-sub { font-size: var(--text-sm); color: var(--ink-700); margin-top: var(--space-2); }
  .ins-disc { font-size: var(--text-xs); color: var(--ink-500); margin-top: var(--space-2); }
  @media (max-width: 640px) { .ins-lead { grid-template-columns: 1fr; } }
</style>
