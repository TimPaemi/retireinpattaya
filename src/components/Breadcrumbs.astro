---
/* Accessible breadcrumbs + matching BreadcrumbList JSON-LD (passed up to <head>). */
import { SITE } from '../site.config';
interface Crumb { label: string; href?: string; }
interface Props { crumbs: Crumb[]; }
const { crumbs } = Astro.props;
const items = [{ label: 'Home', href: '/' }, ...crumbs];
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {items.map((c, i) => (
      <li>
        {c.href && i < items.length - 1
          ? <a href={c.href}>{c.label}</a>
          : <span aria-current="page">{c.label}</span>}
        {i < items.length - 1 && <span class="sep" aria-hidden="true">›</span>}
      </li>
    ))}
  </ol>
</nav>
<style>
  .breadcrumbs ol { list-style: none; display: flex; flex-wrap: wrap; gap: var(--space-2); padding: 0; margin: 0; font-size: var(--text-sm); color: var(--ink-500); }
  .breadcrumbs a { color: var(--brand-700); text-decoration: none; }
  .breadcrumbs a:hover { text-decoration: underline; }
  .breadcrumbs .sep { color: var(--line-strong); margin-left: var(--space-2); }
  .breadcrumbs [aria-current="page"] { color: var(--ink-700); }
</style>
