---
interface Source { label: string; url: string; publisher?: string; accessed?: string; }
interface Props { sources: Source[]; }
const { sources } = Astro.props;
---
{sources.length > 0 && (
  <section class="sources" aria-labelledby="sources-heading">
    <h2 id="sources-heading">Sources &amp; further reading</h2>
    <p class="text-muted">We link to primary and official sources wherever possible. If you spot something out of date, please tell us.</p>
    <ol>
      {sources.map((s) => (
        <li>
          <a href={s.url} rel="nofollow noopener" target="_blank">{s.label}</a>
          {s.publisher && <span class="text-muted"> — {s.publisher}</span>}
          {s.accessed && <span class="text-muted"> (verified {s.accessed})</span>}
        </li>
      ))}
    </ol>
  </section>
)}
<style>
  .sources { margin-top: var(--space-8); padding-top: var(--space-5); border-top: 2px solid var(--line); }
  .sources ol { padding-left: var(--space-6); font-size: var(--text-sm); }
  .sources li { margin-bottom: var(--space-2); }
</style>
