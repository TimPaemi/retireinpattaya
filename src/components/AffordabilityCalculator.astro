---
import { TIERS, AGE_BANDS, CURRENCIES, BENCHMARKS_META } from '../data/benchmarks';
const payload = JSON.stringify({ TIERS, AGE_BANDS, CURRENCIES, BENCHMARKS_META });
---
<section class="calc" aria-labelledby="calc-title">
  <script type="application/json" id="rip-benchmarks" set:html={payload}></script>

  <div class="calc-grid">
    <!-- INPUTS -->
    <form class="calc-inputs" id="calc-form" novalidate>
      <h2 id="calc-title" class="calc-h">Your numbers</h2>

      <div class="field">
        <label for="cur">Your currency</label>
        <select id="cur" name="cur">
          {CURRENCIES.map((c) => <option value={c.code}>{c.code} ({c.symbol})</option>)}
        </select>
      </div>

      <div class="field">
        <label for="inc">Guaranteed monthly income <span class="hint">pensions, annuities — after tax</span></label>
        <div class="input-money"><span class="cur-symbol" data-cursym>£</span><input id="inc" name="inc" type="number" inputmode="decimal" min="0" step="50" placeholder="2000" /><span class="per">/mo</span></div>
      </div>

      <div class="field">
        <label for="sav">Savings you could draw on <span class="hint">your buffer / nest egg</span></label>
        <div class="input-money"><span class="cur-symbol" data-cursym>£</span><input id="sav" name="sav" type="number" inputmode="decimal" min="0" step="1000" placeholder="60000" /></div>
      </div>

      <div class="field">
        <label for="fx">Exchange rate <span class="hint">THB per 1 <span data-curcode>GBP</span> — edit to today's rate</span></label>
        <div class="input-money"><input id="fx" name="fx" type="number" inputmode="decimal" min="0" step="0.1" /><span class="per">฿</span></div>
      </div>

      <fieldset class="field">
        <legend>Lifestyle you want</legend>
        {TIERS.map((t, i) => (
          <label class="tier-option">
            <input type="radio" name="tier" value={t.id} checked={i === 1} />
            <span class="tier-body">
              <span class="tier-label">{t.label} <span class="tier-cost" data-tiercost={t.id}></span></span>
              <span class="tier-blurb">{t.includes}</span>
            </span>
          </label>
        ))}
        <label class="custom-spend">
          <input type="checkbox" id="usecustom" /> Use my own monthly living cost instead
          <span class="input-money custom-money"><span class="cur-symbol" data-cursym>£</span><input id="customspend" type="number" min="0" step="50" disabled placeholder="custom /mo" aria-label="Your own monthly living cost" /></span>
        </label>
      </fieldset>

      <div class="field">
        <label for="age">Your age band <span class="hint">sets a rough insurance estimate</span></label>
        <select id="age" name="age">
          {AGE_BANDS.map((a, i) => <option value={a.id} selected={i === 1}>{a.label}</option>)}
        </select>
        <p class="age-note" data-agenote></p>
      </div>

      <div class="field">
        <label for="ins">Monthly health insurance <span class="hint">estimate — get a real quote</span></label>
        <div class="input-money"><span class="cur-symbol" data-cursym>£</span><input id="ins" name="ins" type="number" inputmode="decimal" min="0" step="50" /><span class="per">/mo</span></div>
      </div>

      <div class="calc-actions">
        <button type="button" class="btn btn-ghost" id="copylink">🔗 Copy shareable link</button>
        <button type="reset" class="btn btn-ghost" id="resetbtn">Reset</button>
      </div>
      <p class="copied" id="copied" hidden>Link copied — paste it anywhere to come back to these numbers.</p>
    </form>

    <!-- RESULTS -->
    <div class="calc-results" aria-live="polite" id="results">
      <div class="verdict" id="verdict">
        <p class="verdict-eyebrow">Your result</p>
        <p class="verdict-head" id="verdict-head">Enter your income to see your result</p>
        <p class="verdict-sub" id="verdict-sub">Everything updates as you type. Nothing you enter leaves your device.</p>
      </div>

      <table class="result-table">
        <tbody>
          <tr><th scope="row">Monthly income</th><td id="r-income">—</td></tr>
          <tr><th scope="row">Living costs (<span id="r-tier">comfortable</span>)</th><td id="r-living">—</td></tr>
          <tr><th scope="row">Health insurance</th><td id="r-ins">—</td></tr>
          <tr class="result-total"><th scope="row" id="r-balance-label">Monthly surplus</th><td id="r-balance">—</td></tr>
        </tbody>
      </table>

      <div class="savings-box">
        <p class="savings-line" id="r-lasts">—</p>
      </div>

      <figure class="chart-wrap">
        <figcaption>Projected savings balance over 25 years <span class="text-muted">(before inflation &amp; investment growth)</span></figcaption>
        <svg id="chart" viewBox="0 0 600 300" role="img" aria-labelledby="chart-title chart-desc" preserveAspectRatio="xMidYMid meet">
          <title id="chart-title">Savings projection chart</title>
          <desc id="chart-desc">A line showing how your savings balance changes month by month over 25 years based on your monthly surplus or shortfall.</desc>
        </svg>
      </figure>

      <p class="calc-caveat text-muted">
        A starting point, not a forecast. It ignores inflation, investment returns, one-off costs and life's surprises.
        See <a href="/methodology/">how this works</a>. Benchmarks last reviewed {BENCHMARKS_META.lastReviewed}.
      </p>
    </div>
  </div>
</section>

<style>
  .calc { margin-block: var(--space-6); }
  .calc-grid { display: grid; grid-template-columns: 1fr 1.05fr; gap: var(--space-6); align-items: start; }
  .calc-inputs, .calc-results { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: var(--space-5); box-shadow: var(--shadow-sm); }
  .calc-results { background: var(--brand-050); border-color: var(--brand-100); position: sticky; top: 88px; }
  .calc-h { margin: 0 0 var(--space-4); font-size: var(--text-xl); }
  .field { margin-bottom: var(--space-5); border: 0; padding: 0; }
  .field > label, .field > legend { display: block; font-weight: 600; margin-bottom: var(--space-2); }
  .hint { display: block; font-weight: 400; font-size: var(--text-xs); color: var(--ink-500); }
  select, input[type="number"] { width: 100%; padding: var(--space-3) var(--space-4); font-size: var(--text-base); border: 2px solid var(--line-strong); border-radius: var(--radius-sm); background: #fff; min-height: 50px; }
  .input-money { display: flex; align-items: stretch; border: 2px solid var(--line-strong); border-radius: var(--radius-sm); overflow: hidden; background: #fff; }
  .input-money input { border: 0; border-radius: 0; min-height: 48px; }
  .input-money:focus-within { outline: 3px solid var(--brand-600); outline-offset: 1px; }
  .cur-symbol, .per { display: grid; place-items: center; padding-inline: var(--space-3); background: var(--surface-sunken); color: var(--ink-700); font-weight: 600; }
  .tier-option { display: flex; gap: var(--space-3); align-items: flex-start; padding: var(--space-3); border: 2px solid var(--line); border-radius: var(--radius); margin-bottom: var(--space-2); cursor: pointer; }
  .tier-option:has(input:checked) { border-color: var(--brand-600); background: #fff; box-shadow: var(--shadow-sm); }
  .tier-option input { margin-top: .35em; width: auto; min-height: 0; }
  .tier-label { font-weight: 700; display: block; }
  .tier-cost { color: var(--brand-700); font-weight: 700; }
  .tier-blurb { font-size: var(--text-sm); color: var(--ink-500); }
  .custom-spend { display: block; font-size: var(--text-sm); margin-top: var(--space-2); }
  .custom-money { margin-top: var(--space-2); max-width: 16rem; }
  .age-note { font-size: var(--text-xs); color: var(--warn-700); margin-top: var(--space-2); min-height: 1em; }
  .calc-actions { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-4); }
  .copied { color: var(--ok-700); font-size: var(--text-sm); margin-top: var(--space-2); }
  .verdict { padding: var(--space-4); border-radius: var(--radius); background: #fff; border: 1px solid var(--line); margin-bottom: var(--space-4); }
  .verdict.is-good { border-left: 6px solid var(--ok-700); }
  .verdict.is-tight { border-left: 6px solid var(--warn-700); }
  .verdict.is-short { border-left: 6px solid var(--danger-700); }
  .verdict-eyebrow { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: .08em; color: var(--ink-500); font-weight: 700; }
  .verdict-head { font-family: var(--font-serif); font-size: var(--text-xl); color: var(--brand-900); margin-top: var(--space-1); }
  .verdict-sub { font-size: var(--text-sm); color: var(--ink-700); margin-top: var(--space-2); }
  .result-table { width: 100%; }
  .result-table th, .result-table td { padding: var(--space-3) var(--space-2); }
  .result-table td { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; }
  .result-total th, .result-total td { border-top: 2px solid var(--line-strong); font-size: var(--text-lg); }
  .savings-box { margin: var(--space-4) 0; padding: var(--space-4); background: #fff; border: 1px solid var(--line); border-radius: var(--radius); }
  .savings-line { margin: 0; }
  .chart-wrap { margin: var(--space-4) 0 0; }
  .chart-wrap figcaption { font-size: var(--text-xs); color: var(--ink-500); margin-bottom: var(--space-2); }
  #chart { width: 100%; height: auto; background: #fff; border: 1px solid var(--line); border-radius: var(--radius); }
  .calc-caveat { font-size: var(--text-xs); margin-top: var(--space-3); }
  @media (max-width: 820px) { .calc-grid { grid-template-columns: 1fr; } .calc-results { position: static; } }
</style>

<script is:inline>
(function () {
  var data = JSON.parse(document.getElementById('rip-benchmarks').textContent);
  var TIERS = data.TIERS, AGE_BANDS = data.AGE_BANDS, CURRENCIES = data.CURRENCIES;
  var $ = function (id) { return document.getElementById(id); };
  var form = $('calc-form');
  if (!form) return;

  function cur() { return CURRENCIES.find(function (c) { return c.code === $('cur').value; }) || CURRENCIES[0]; }
  function tier() { var el = form.querySelector('input[name="tier"]:checked'); return TIERS.find(function (t) { return t.id === (el && el.value); }) || TIERS[1]; }
  function ageBand() { return AGE_BANDS.find(function (a) { return a.id === $('age').value; }) || AGE_BANDS[1]; }
  function num(el) { var v = parseFloat(el.value); return isFinite(v) && v >= 0 ? v : 0; }

  function fmtHome(n) { var c = cur(); return c.symbol + Math.round(n).toLocaleString('en-GB'); }
  function fmtTHB(n) { return '฿' + Math.round(n).toLocaleString('en-GB'); }

  // Keep currency symbols + FX default + tier costs in sync with chosen currency
  function syncCurrencyUI() {
    var c = cur();
    Array.prototype.forEach.call(document.querySelectorAll('[data-cursym]'), function (s) { s.textContent = c.symbol; });
    Array.prototype.forEach.call(document.querySelectorAll('[data-curcode]'), function (s) { s.textContent = c.code; });
    TIERS.forEach(function (t) {
      var span = document.querySelector('[data-tiercost="' + t.id + '"]');
      if (span) span.textContent = '· ' + fmtTHB(t.monthlyTHB) + '/mo';
    });
  }
  function setFxDefaultIfEmpty(force) { if (force || !$('fx').value) $('fx').value = cur().thbPerUnit; }
  function setInsuranceDefault(force) {
    var c = cur(), band = ageBand();
    if (force || !$('ins').value) $('ins').value = Math.round(band.insuranceMonthlyTHB / c.thbPerUnit);
    var note = $('results').querySelector ? document.querySelector('[data-agenote]') : null;
    if (note) note.textContent = band.note || '';
  }

  function compute() {
    var c = cur();
    var fx = num($('fx')) || c.thbPerUnit;
    var incomeTHB = num($('inc')) * fx;
    var savingsTHB = num($('sav')) * fx;
    var insTHB = num($('ins')) * fx;
    var livingTHB = $('usecustom').checked && num($('customspend')) > 0 ? num($('customspend')) * fx : tier().monthlyTHB;
    var costsTHB = livingTHB + insTHB;
    var surplusTHB = incomeTHB - costsTHB;
    return { c: c, fx: fx, incomeTHB: incomeTHB, savingsTHB: savingsTHB, insTHB: insTHB, livingTHB: livingTHB, costsTHB: costsTHB, surplusTHB: surplusTHB };
  }

  function yearsMonths(months) {
    if (!isFinite(months)) return '';
    var y = Math.floor(months / 12), m = Math.round(months % 12);
    var parts = [];
    if (y) parts.push(y + (y === 1 ? ' year' : ' years'));
    if (m) parts.push(m + (m === 1 ? ' month' : ' months'));
    return parts.join(' ') || 'under a month';
  }

  function render() {
    var r = compute();
    var fxOf = function (thb) { return thb / r.fx; };
    $('r-income').textContent = fmtHome(fxOf(r.incomeTHB)) + ' · ' + fmtTHB(r.incomeTHB);
    $('r-tier').textContent = $('usecustom').checked ? 'your figure' : tier().label.toLowerCase();
    $('r-living').textContent = fmtTHB(r.livingTHB);
    $('r-ins').textContent = fmtTHB(r.insTHB);

    var v = $('verdict');
    v.classList.remove('is-good', 'is-tight', 'is-short');
    var balLabel = $('r-balance-label'), bal = $('r-balance');

    if (r.incomeTHB <= 0) {
      $('verdict-head').textContent = 'Enter your income to see your result';
      $('verdict-sub').textContent = 'Everything updates as you type. Nothing you enter leaves your device.';
      bal.textContent = '—'; $('r-lasts').textContent = '—';
      drawChart([]); return;
    }

    if (r.surplusTHB >= 0) {
      balLabel.textContent = 'Monthly surplus';
      bal.textContent = '+' + fmtTHB(r.surplusTHB);
      v.classList.add('is-good');
      $('verdict-head').textContent = 'On these numbers, your income covers this lifestyle.';
      var buffMonths = r.costsTHB > 0 ? r.savingsTHB / r.costsTHB : Infinity;
      $('verdict-sub').textContent = 'You have a monthly surplus of ' + fmtTHB(r.surplusTHB) + ' (' + fmtHome(r.surplusTHB / r.fx) + '), and your savings stay intact as a buffer.';
      $('r-lasts').innerHTML = '<strong>Your savings are a reserve, not a runway.</strong> They cover about <strong>' + (isFinite(buffMonths) ? yearsMonths(buffMonths) : '—') + '</strong> of total costs if your income ever stopped.';
    } else {
      var deficit = -r.surplusTHB;
      balLabel.textContent = 'Monthly shortfall';
      bal.textContent = '−' + fmtTHB(deficit);
      var months = r.savingsTHB > 0 ? r.savingsTHB / deficit : 0;
      if (months >= 300) { v.classList.add('is-tight'); } else { v.classList.add('is-short'); }
      $('verdict-head').textContent = 'There’s a monthly shortfall — savings would top it up.';
      $('verdict-sub').textContent = 'You’re short ' + fmtTHB(deficit) + ' (' + fmtHome(deficit / r.fx) + ') a month, drawn from savings.';
      $('r-lasts').innerHTML = months > 0
        ? 'At this rate your savings would last about <strong>' + yearsMonths(months) + '</strong>' + (months < 240 ? ' — worth a careful rethink of income, lifestyle tier, or timing.' : '.')
        : '<strong>With no savings buffer, this lifestyle isn’t sustainable on this income.</strong> Consider a leaner tier or more income.';
    }
    drawChart(buildSeries(r));
    updateShareLink();
  }

  function buildSeries(r) {
    var pts = [], bal = r.savingsTHB;
    for (var m = 0; m <= 300; m++) { pts.push(bal); bal += r.surplusTHB; if (bal < 0) bal = 0; }
    return pts;
  }

  function drawChart(series) {
    var svg = $('chart'); if (!svg) return;
    while (svg.childNodes.length > 2) svg.removeChild(svg.lastChild); // keep <title>,<desc>
    var W = 600, H = 300, pad = 40;
    if (!series.length) return;
    var max = Math.max.apply(null, series.concat([1]));
    var x = function (i) { return pad + (i / 300) * (W - pad - 10); };
    var y = function (val) { return H - pad - (val / max) * (H - pad - 20); };
    var NS = 'http://www.w3.org/2000/svg';
    function add(tag, attrs) { var e = document.createElementNS(NS, tag); for (var k in attrs) e.setAttribute(k, attrs[k]); svg.appendChild(e); return e; }

    add('line', { x1: pad, y1: H - pad, x2: W - 10, y2: H - pad, stroke: '#c4d0d5', 'stroke-width': 1 });
    add('line', { x1: pad, y1: 20, x2: pad, y2: H - pad, stroke: '#c4d0d5', 'stroke-width': 1 });
    [0, 5, 10, 15, 20, 25].forEach(function (yr) {
      var px = x(yr * 12);
      add('line', { x1: px, y1: H - pad, x2: px, y2: H - pad + 5, stroke: '#c4d0d5' });
      var t = add('text', { x: px, y: H - pad + 18, 'text-anchor': 'middle', 'font-size': 11, fill: '#4a5a62' }); t.textContent = yr + 'y';
    });
    var top = add('text', { x: pad - 6, y: 24, 'text-anchor': 'end', 'font-size': 11, fill: '#4a5a62' }); top.textContent = '฿' + Math.round(max).toLocaleString('en-GB');

    var d = series.map(function (v, i) { return (i === 0 ? 'M' : 'L') + x(i).toFixed(1) + ' ' + y(v).toFixed(1); }).join(' ');
    var area = d + ' L' + x(300).toFixed(1) + ' ' + (H - pad) + ' L' + x(0).toFixed(1) + ' ' + (H - pad) + ' Z';
    add('path', { d: area, fill: 'rgba(27,127,140,0.10)' });
    add('path', { d: d, fill: 'none', stroke: '#0e4d64', 'stroke-width': 2.5 });

    var zeroIdx = -1;
    for (var i = 0; i < series.length; i++) { if (series[i] <= 0) { zeroIdx = i; break; } }
    if (zeroIdx > 0) {
      var px = x(zeroIdx);
      add('circle', { cx: px, cy: y(0), r: 4, fill: '#9a2a2a' });
      var lbl = add('text', { x: Math.min(px + 6, W - 80), y: y(0) - 8, 'font-size': 11, fill: '#9a2a2a', 'font-weight': 600 });
      lbl.textContent = 'savings gone ~' + (zeroIdx / 12).toFixed(1) + 'y';
    }
  }

  // ---- Shareable URL (no backend) ----
  function updateShareLink() {
    var p = new URLSearchParams();
    p.set('cur', $('cur').value); p.set('inc', $('inc').value || ''); p.set('sav', $('sav').value || '');
    p.set('fx', $('fx').value || ''); p.set('tier', (form.querySelector('input[name=tier]:checked') || {}).value || '');
    p.set('age', $('age').value); p.set('ins', $('ins').value || '');
    if ($('usecustom').checked) p.set('spend', $('customspend').value || '');
    history.replaceState(null, '', location.pathname + '?' + p.toString());
  }
  function loadFromURL() {
    var p = new URLSearchParams(location.search);
    if (p.get('cur')) $('cur').value = p.get('cur');
    syncCurrencyUI();
    if (p.get('fx')) $('fx').value = p.get('fx'); else setFxDefaultIfEmpty(true);
    if (p.get('inc')) $('inc').value = p.get('inc');
    if (p.get('sav')) $('sav').value = p.get('sav');
    if (p.get('age')) $('age').value = p.get('age');
    if (p.get('tier')) { var r = form.querySelector('input[name=tier][value="' + p.get('tier') + '"]'); if (r) r.checked = true; }
    if (p.get('spend')) { $('usecustom').checked = true; $('customspend').disabled = false; $('customspend').value = p.get('spend'); }
    if (p.get('ins')) $('ins').value = p.get('ins'); else setInsuranceDefault(true);
  }

  // ---- Wire events ----
  $('cur').addEventListener('change', function () { syncCurrencyUI(); setFxDefaultIfEmpty(true); setInsuranceDefault(true); render(); });
  $('age').addEventListener('change', function () { setInsuranceDefault(true); render(); });
  $('usecustom').addEventListener('change', function () { $('customspend').disabled = !this.checked; render(); });
  form.addEventListener('input', render);
  form.addEventListener('change', render);
  $('resetbtn').addEventListener('click', function () {
    setTimeout(function () { syncCurrencyUI(); setFxDefaultIfEmpty(true); setInsuranceDefault(true); render(); }, 0);
  });
  $('copylink').addEventListener('click', function () {
    updateShareLink();
    var url = location.href;
    if (navigator.clipboard) navigator.clipboard.writeText(url);
    var c = $('copied'); c.hidden = false; setTimeout(function () { c.hidden = true; }, 4000);
  });

  // ---- Init ----
  syncCurrencyUI(); setFxDefaultIfEmpty(false); setInsuranceDefault(false);
  loadFromURL();
  render();
})();
</script>
