---
/* SEO + social + structured-data <head>. Reads sensible defaults from SITE. */
import { SITE, ANALYTICS } from '../site.config';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schemas?: Record<string, unknown>[];   // extra JSON-LD blocks (Article, FAQ, Breadcrumb…)
}

const {
  title,
  description = SITE.description,
  image = SITE.defaultOgImage,
  type = 'website',
  noindex = false,
  schemas = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
const ogImage = new URL(image, Astro.site ?? SITE.url).href;
// Social title keeps the brand for richer cards.
const fullTitle = title === SITE.name ? title : `${title} — ${SITE.name}`;
// <title> tag is kept <=60 chars so Google shows it without truncation.
// Page titles already lead with the topic + Pattaya/Thailand keywords, so when
// the branded form is too long we fall back to the (already keyword-rich) title.
const metaTitle = fullTitle.length <= 60
  ? fullTitle
  : (title.length <= 60 ? title : `${title.slice(0, 59).trimEnd()}…`);

// Always-present site identity schema.
const baseSchemas: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    description: SITE.description,
    email: SITE.email,
    ...(SITE.sameAs.length ? { sameAs: SITE.sameAs } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    inLanguage: 'en',
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `${SITE.url}/search/?q={search_term_string}` },
      'query-input': 'required name=search_term_string',
    },
  },
];
const allSchemas = [...baseSchemas, ...schemas];
---
<meta charset="utf-8" />
<script is:inline>(function(){try{var s=localStorage.getItem("rip-textsize"),m={normal:"100%",large:"112%",xlarge:"125%"};if(s&&m[s])document.documentElement.style.fontSize=m[s];}catch(e){}})();</script>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#0e4d64" />
<link rel="canonical" href={canonical} />
<meta name="generator" content={Astro.generator} />

<title>{metaTitle}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={fullTitle} />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={fullTitle} />

<!-- Structured data -->
{allSchemas.map((s) => (
  <script type="application/ld+json" set:html={JSON.stringify(s)} />
))}

<link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

{ANALYTICS.provider === 'plausible' && ANALYTICS.domain && (
  <script is:inline defer data-domain={ANALYTICS.domain} src="https://plausible.io/js/script.js"></script>
)}
{ANALYTICS.provider === 'umami' && ANALYTICS.src && (
  <script is:inline defer src={ANALYTICS.src} data-website-id={ANALYTICS.domain}></script>
)}
