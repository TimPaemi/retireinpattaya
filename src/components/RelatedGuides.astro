---
import type { CollectionEntry } from 'astro:content';
interface Props { guides: { slug: string; pillar: string; title: string; description: string }[]; }
const { guides } = Astro.props;
---
{guides.length > 0 && (
  <section class="related" aria-labelledby="related-h">
    <h2 id="related-h">Keep reading</h2>
    <div class="grid grid-2">
      {guides.map((g) => (
        <a class="card card-link" href={`/${g.pillar}/${g.slug}/`}>
          <h3 class="mt-0">{g.title}</h3>
          <p class="text-muted">{g.description}</p>
        </a>
      ))}
    </div>
  </section>
)}
<style>
  .related { margin-top: var(--space-10); }
</style>
