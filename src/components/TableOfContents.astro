---
interface Heading { depth: number; slug: string; text: string; }
interface Props { headings: Heading[]; }
const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
{toc.length > 2 && (
  <nav class="toc" aria-label="On this page">
    <p class="toc-title">On this page</p>
    <ol>
      {toc.map((h) => (
        <li class={`toc-d${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>
      ))}
    </ol>
  </nav>
)}
<style>
  .toc { font-size: var(--text-sm); }
  .toc-title { text-transform: uppercase; letter-spacing: .06em; font-size: var(--text-xs); font-weight: 700; color: var(--ink-500); margin-bottom: var(--space-2); }
  .toc ol { list-style: none; padding: 0; margin: 0; border-left: 2px solid var(--line); }
  .toc li { margin: 0; }
  .toc a { display: block; padding: var(--space-1) var(--space-3); color: var(--ink-700); text-decoration: none; border-left: 2px solid transparent; margin-left: -2px; }
  .toc a:hover { color: var(--brand-700); border-left-color: var(--brand-500); background: var(--brand-050); }
  .toc-d3 a { padding-left: var(--space-5); font-size: .95em; color: var(--ink-500); }
</style>
