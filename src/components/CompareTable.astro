---
interface Props { headers: string[]; rows: string[][]; caption?: string; }
const { headers, rows, caption } = Astro.props;
---
<figure class="compare">
  {caption && <figcaption>{caption}</figcaption>}
  <div class="table-wrap">
    <table>
      <thead><tr>{headers.map((h) => <th scope="col">{h}</th>)}</tr></thead>
      <tbody>
        {rows.map((r) => (
          <tr>{r.map((cell, i) => (i === 0 ? <th scope="row">{cell}</th> : <td>{cell}</td>))}</tr>
        ))}
      </tbody>
    </table>
  </div>
</figure>
<style>
  .compare { margin-block: var(--space-5); }
  .compare figcaption { font-size: var(--text-sm); color: var(--ink-500); margin-bottom: var(--space-2); }
  .compare th[scope="row"] { font-weight: 700; color: var(--brand-900); background: var(--brand-050); }
</style>
