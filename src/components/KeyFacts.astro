---
interface Fact { label: string; value: string; verify?: boolean; sourceUrl?: string; }
interface Props { facts: Fact[]; }
const { facts } = Astro.props;
---
{facts.length > 0 && (
  <aside class="keyfacts" aria-label="Key facts">
    <p class="keyfacts-title">Key facts at a glance</p>
    <dl>
      {facts.map((f) => (
        <div class="kf-row">
          <dt>{f.label}</dt>
          <dd>
            {f.value}
            {f.verify && <span class="verify-flag">⚠ verify</span>}
            {f.sourceUrl && <a class="kf-src" href={f.sourceUrl} rel="nofollow noopener" target="_blank" aria-label="source">↗</a>}
          </dd>
        </div>
      ))}
    </dl>
    <p class="keyfacts-note">Figures marked “verify” change often — confirm against the official source before acting.</p>
  </aside>
)}
<style>
  .keyfacts { background: var(--brand-050); border: 1px solid var(--brand-100); border-radius: var(--radius-lg); padding: var(--space-5); margin-block: var(--space-5); }
  .keyfacts-title { font-family: var(--font-serif); font-weight: 600; color: var(--brand-900); font-size: var(--text-lg); margin-bottom: var(--space-3); }
  .keyfacts dl { margin: 0; display: grid; gap: 0; }
  .kf-row { display: grid; grid-template-columns: 1fr 1.3fr; gap: var(--space-4); padding: var(--space-2) 0; border-bottom: 1px solid var(--brand-100); }
  .kf-row:last-of-type { border-bottom: 0; }
  .kf-row dt { color: var(--ink-500); font-weight: 600; font-size: var(--text-sm); }
  .kf-row dd { margin: 0; font-weight: 600; color: var(--ink-900); }
  .kf-src { margin-left: 6px; text-decoration: none; color: var(--brand-600); }
  .keyfacts-note { font-size: var(--text-xs); color: var(--ink-500); margin-top: var(--space-3); }
  @media (max-width: 520px) { .kf-row { grid-template-columns: 1fr; gap: 2px; } }
</style>
