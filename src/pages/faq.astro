---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Disclaimer from '../components/Disclaimer.astro';
import { SITE_FAQS } from '../data/faqs';
import { SITE } from '../site.config';

const categories = [...new Set(SITE_FAQS.map((f) => f.category))];
const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: SITE_FAQS.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---
<BaseLayout title="Frequently Asked Questions" description="Honest, plain answers to the questions people ask most about retiring in Pattaya — money, visas, healthcare, safety and loneliness." schemas={[faqSchema]}>
  <section class="section"><div class="container container-narrow">
    <Breadcrumbs crumbs={[{ label: 'FAQ' }]} />
    <h1>Frequently asked questions</h1>
    <p class="lead">Short, honest answers. Where a figure changes often, we say so rather than guess.</p>
    {categories.map((cat) => (
      <div class="faq-cat">
        <h2>{cat}</h2>
        {SITE_FAQS.filter((f) => f.category === cat).map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    ))}
    <div class="mt-8"><Disclaimer topic="general" /></div>
  </div></section>
</BaseLayout>
<style>
  .faq-cat { margin-top: var(--space-6); }
  .faq-item { border: 1px solid var(--line); border-radius: var(--radius); padding: var(--space-3) var(--space-4); margin-bottom: var(--space-3); background: #fff; }
  .faq-item summary { font-weight: 700; cursor: pointer; color: var(--brand-900); }
  .faq-item p { margin-top: var(--space-3); }
</style>
