---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PILLARS } from '../site.config';
const top = [...PILLARS].sort((a,b)=>a.priority-b.priority).slice(0,6);
---
<BaseLayout title="Page Not Found" description="That page couldn't be found — here are some good places to start instead." noindex={true}>
  <section class="section"><div class="container container-narrow text-center">
    <p class="eyebrow">Error 404</p>
    <h1>We couldn't find that page</h1>
    <p class="lead">It may have moved, or the link might be slightly off. Here are some good places to start.</p>
    <p class="mt-6">
      <a class="btn btn-primary" href="/start-here/">Start here</a>
      <a class="btn btn-ghost" href="/tools/can-i-afford-to-retire-in-pattaya/">Affordability calculator</a>
    </p>
    <h2 class="visually-hidden">Popular sections</h2>
    <div class="grid grid-3 mt-8" style="text-align:left;">
      {top.map((p)=>(
        <a class="card card-link" href={`/${p.slug}/`}>
          <span aria-hidden="true" style="font-size:1.6rem">{p.icon}</span>
          <h3 class="mt-0">{p.title}</h3>
        </a>
      ))}
    </div>
  </div></section>
</BaseLayout>
