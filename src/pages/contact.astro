---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../site.config';
---
<BaseLayout title="Contact Us" description="Get in touch — corrections, questions, or to suggest a guide. We especially want to hear if something is out of date.">
  <section class="section"><div class="container container-narrow prose flow">
    <Breadcrumbs crumbs={[{ label: 'Contact' }]} />
    <h1>Contact Us</h1>
    <p class="lead">We'd love to hear from you — especially if you spot something out of date.</p>
    <p>Email us at <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.</p>
    <h2>Corrections</h2>
    <p>This is a money/health/legal resource, so accuracy matters enormously. If a figure looks wrong or a rule has changed, please tell us which page and what you found — we'll check it and update the review date.</p>
    <h2>A note on advice</h2>
    <p>We can't give personal financial, legal, medical or immigration advice, and we can't recommend an individual's specific course of action. For that, please speak to a qualified professional — we're glad to explain the general lay of the land.</p>
  </div></section>
</BaseLayout>
