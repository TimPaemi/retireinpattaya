# Security + caching headers for Cloudflare Pages (also works on Netlify).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://plausible.io; connect-src 'self' https://plausible.io; font-src 'self'; base-uri 'self'; form-action 'self' https:; frame-ancestors 'self'

# The embeddable calculator must be frameable on other sites:
/embed/*
  Content-Security-Policy: frame-ancestors *

# Fingerprinted assets can be cached forever:
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# PDFs and images: cache a day:
/downloads/*
  Cache-Control: public, max-age=86400
/og-default.png
  Cache-Control: public, max-age=86400
